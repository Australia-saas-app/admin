# Copy this file to `.env` for Docker Compose (preferred).
# Host `apps/*/.env.local` installs are not required when running via Docker.
#
#   cp .env.example .env
#   docker compose up --build
# ==============================================================================

# Backend API
# ------------------------------------------------------------------------------
# ------------------------------------------------------------------------------

# From containers, use host.docker.internal to reach an API on the host machine.
NEXT_PUBLIC_BACKEND_URL=http://host.docker.internal:3006

# WebSocket / live chat server (optional — chat works offline when unset)
# NEXT_PUBLIC_SOCKET_URL=http://localhost:8000

# Protected super administrator account ID (defaults to SUPER001)
# NEXT_PUBLIC_SUPER_ADMIN_ID=SUPER001

# API version prefix. All relative API paths resolve against
# <NEXT_PUBLIC_BACKEND_URL>/api/<NEXT_PUBLIC_API_VERSION>.
# Defaults to "v1"; set to an empty string to call the backend root directly.
# NEXT_PUBLIC_API_VERSION=v1

# ------------------------------------------------------------------------------
# Application Meta
# ------------------------------------------------------------------------------

# Application display name (shown in <title> and metadata)
# NEXT_PUBLIC_APP_NAME=System DB

# Public site URL for the main web app (no trailing slash)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin console URL when running as a separate app (no trailing slash)
# NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Runtime environment (development | staging | production)
# NEXT_PUBLIC_APP_ENV=development

# Feature flags (comma-separated). Known flags:
#   maintenance_mode – shows a site-wide maintenance banner
#   new_dashboard, beta_chat, analytics_v2, export_csv, dark_mode_toggle
# NEXT_PUBLIC_ENABLE_FEATURE_FLAGS=

# ------------------------------------------------------------------------------
# GCP / Production deployment
# Set these before `gcloud builds submit` or docker compose prod builds.
# NEXT_PUBLIC_* values are embedded at build time — rebuild after changes.
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_BACKEND_URL=https://api.yourdomain.com
# NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.yourdomain.com

# Runtime cookie security (optional)
# Secure cookies only work over HTTPS. For HTTP VM access (http://IP:port), set:
# COOKIE_SECURE=false
# For HTTPS domains, set COOKIE_SECURE=true (or omit and rely on https SITE_URL)
# COOKIE_SECURE=false


# ------------------------------------------------------------------------------
# Optional: Analytics / Monitoring (add your own as needed)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
