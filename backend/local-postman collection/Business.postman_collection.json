    {
      "name": "Order Management",
       "item": [
         {
           "name": "Create Order",
           "request": {
             "method": "POST",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{token}}"
               },
               {
                 "key": "Content-Type",
                 "value": "application/json"
               }
             ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"orderType\": \"technology\",\n  \"serviceName\": \"Web Development Service\",\n  \"clientInfo\": {\n    \"fullName\": \"John Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone\": \"+1234567890\"\n  },\n  \"pricing\": {\n    \"totalAmount\": 25000,\n    \"currency\": \"USD\"\n  },\n  \"orderDetails\": {\n    \"projectType\": \"E-commerce website development\",\n    \"priorityLevel\": \"high\",\n    \"expectedEndDate\": \"2024-12-31\"\n  }\n}"
             },
             "url": {
               "raw": "{{orderUrl}}/api/orders",
               "host": ["localhost:3011"],
               "path": ["api", "orders"]
             },
             "description": "Create a new order for a service"
           },
           "response": []
         },
         {
           "name": "List All Orders",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
             "url": {
               "raw": "{{orderUrl}}/api/orders?page=1&limit=20&status=working",
               "host": ["localhost:3011"],
               "path": ["api", "orders"],
               "query": [
                 {
                   "key": "page",
                   "value": "1"
                 },
                 {
                   "key": "limit",
                   "value": "20"
                 },
                 {
                   "key": "status",
                   "value": "working",
                   "disabled": true
                 },
                 {
                   "key": "orderType",
                   "value": "",
                   "disabled": true
                 },
                 {
                   "key": "search",
                   "value": "",
                   "disabled": true
                 }
               ]
             },
             "description": "List all orders with filtering options"
           },
           "response": []
         },
         {
            "name": "Get Order Details",
            "request": {
              "method": "GET",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                }
              ],
             "url": {
               "raw": "{{orderUrl}}/api/orders/{{orderCode}}",
               "host": ["localhost:3011"],
               "path": ["api", "orders", "{{orderCode}}"]
             },
             "description": "Get detailed information about a specific order"
           },
           "response": []
         },
         {
            "name": "Update Order (Pending Status)",
            "request": {
              "method": "PATCH",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                },
               {
                 "key": "Content-Type",
                 "value": "application/json"
               }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"serviceName\": \"Updated Service Name\",\n  \"pricing\": {\n    \"totalAmount\": 30000,\n    \"currency\": \"USD\"\n  },\n  \"orderDetails\": {\n    \"expectedEndDate\": \"2024-12-31\"\n  }\n}"
             },
             "url": {
               "raw": "{{orderUrl}}/api/orders/{{orderCode}}",
               "host": ["localhost:3011"],
               "path": ["api", "orders", "{{orderCode}}"]
             },
             "description": "Update order details while in pending status"
           },
           "response": []
          }
      ]
    },
