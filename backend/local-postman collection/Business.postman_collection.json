            "response": []
          },
          {
            "name": "Refund Transaction",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                },
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"transactionId\": \"txn_123456\",\n  \"amount\": 500.00,\n  \"reason\": \"Customer requested refund\"\n}"
              },
              "url": {
                "raw": "http://localhost:3004/api/payment/wallet/refund",
                "host": ["localhost:3004"],
                "path": ["api", "payment", "wallet", "refund"]
              },
              "description": "Refund a completed transaction"
            },
            "response": []
          },
          {
            "name": "Get Wallet Balance",
            "request": {
              "method": "GET",
              "header": [
