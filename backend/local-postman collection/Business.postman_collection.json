              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                },
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"amount\": 1000.00,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"stripe\"\n}"
              },
              "url": {
                "raw": "http://localhost:3004/api/payment/wallet/buy",
                "host": ["localhost:3004"],
                "path": ["api", "payment", "wallet", "buy"]
              },
              "description": "Add funds to wallet"
            },
            "response": []
          },
          {
            "name": "Withdraw from Wallet",
            "request": {
              "method": "POST",
              "header": [
                {
                  "key": "Authorization",
                  "value": "Bearer {{token}}"
                },
                {
                  "key": "Content-Type",
