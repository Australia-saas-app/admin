{
  "info": {
    "_postman_id": "business-collection-id",
    "name": "Business Collection - Vero2",
    "description": "Comprehensive business-related endpoints covering Profile Management, Business Verification & Approval, Order Management, Payment/Wallet Integration, Business Performance Analytics, Business Roles & Permissions, Wallet Services, Notifications, and Business Status Management. Uses admin JWT tokens for authentication.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Profile Management",
      "item": [
        {
          "name": "Get Business Profile",
          "request": {
            "method": "GET",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{token}}"
               }
             ],
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile"]
            },
            "description": "Get current business user profile information"
          },
          "response": []
        },
        {
          "name": "Update Business Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Updated Business Name\",\n  \"profilePhoto\": \"https://storage.example.com/photos/profile.jpg\",\n  \"nationality\": \"American\",\n  \"dateOfBirth\": \"1990-01-01\",\n  \"currency\": \"USD\",\n  \"country\": \"United States\",\n  \"state\": \"California\",\n  \"city\": \"San Francisco\",\n  \"zipCode\": \"94105\",\n  \"permanentAddress\": \"123 Business St, San Francisco, CA 94105\"\n}"
            },
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile"]
            },
            "description": "Update business profile information"
          },
          "response": []
        },
        {
          "name": "Verify Business Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profilePhoto\": \"https://storage.example.com/photos/profile.jpg\",\n  \"fullName\": \"John Doe\",\n  \"nationality\": \"American\",\n  \"dateOfBirth\": \"1990-01-01\",\n  \"identityNumber\": \"A123456789\",\n  \"identityType\": \"passport\",\n  \"documentUrl\": \"https://storage.example.com/documents/passport.pdf\"\n}"
            },
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile/verify",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile", "verify"]
            },
            "description": "Verify business profile with identity proof"
          },
          "response": []
        },
        {
          "name": "Update Profile Photo",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"photoUrl\": \"https://storage.example.com/photos/profile.jpg\"\n}"
            },
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile/photo",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile", "photo"]
            },
            "description": "Update business profile photo"
          },
          "response": []
        },
        {
          "name": "Get Business Contacts",
          "request": {
            "method": "GET",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{token}}"
               }
             ],
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile/contacts",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile", "contacts"]
            },
            "description": "Get business contact information"
          },
          "response": []
        },
        {
          "name": "Send OTP for Contact Verification",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contact@business.com\",\n  \"type\": \"profile-contact\"\n}"
            },
            "url": {
              "raw": "{{ssoUrl}}/sso/auth/send-otp",
              "host": ["{{ssoUrl}}"],
              "path": ["sso", "auth", "send-otp"]
            },
            "description": "Send OTP to email or phone for contact verification before adding contact. IMPORTANT: Use type: 'profile-contact' (not 'contact_verification')"
          },
          "response": []
        },
        {
          "name": "Add Business Contact",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"email\",\n  \"value\": \"contact@business.com\",\n  \"otp\": \"123456\"\n}"
            },
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile/contacts",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile", "contacts"]
            },
            "description": "Add a new business contact (requires OTP from Send OTP for Contact Verification)"
          },
          "response": []
        },
        {
          "name": "Set Primary Contact",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"contactId\": \"contact-uuid-here\"\n}"
            },
            "url": {
              "raw": "http://localhost:3005/user-profile-service/profile/contacts/primary",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "profile", "contacts", "primary"]
            },
            "description": "Set a contact as the primary contact"
          },
          "response": []
        },
        {
          "name": "Get Business Preferences",
          "request": {
            "method": "GET",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{token}}"
               }
             ],
            "url": {
              "raw": "http://localhost:3005/user-profile-service/preferences",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "preferences"]
            },
            "description": "Get business user preferences"
          },
          "response": []
        },
        {
          "name": "Update Business Preferences",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{businessToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currency\": \"USD\",\n  \"language\": \"en\",\n  \"theme\": \"light\",\n  \"emailNotifications\": true,\n  \"smsNotifications\": false,\n  \"pushNotifications\": true,\n  \"twoFactorEnabled\": true,\n  \"twoFactorMethod\": \"email\",\n  \"notificationSettings\": {\n    \"orderUpdates\": true,\n    \"paymentAlerts\": true\n  },\n  \"privacySettings\": {\n    \"profileVisibility\": \"private\",\n    \"contactInfoVisible\": false\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3005/user-profile-service/preferences",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "preferences"]
            },
            "description": "Update business user preferences"
          },
          "response": []
        },
        {
          "name": "Get Business Activity Logs",
          "request": {
            "method": "GET",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{token}}"
               }
             ],
            "url": {
              "raw": "http://localhost:3005/user-profile-service/activity?page=1&limit=20",
              "host": ["localhost:3005"],
              "path": ["user-profile-service", "activity"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get business user activity logs"
          },
          "response": []
