              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"amount\": 500.00,\n  \"currency\": \"USD\",\n  \"withdrawalMethod\": \"bank_transfer\",\n  \"accountDetails\": {\n    \"accountNumber\": \"****1234\",\n    \"routingNumber\": \"****5678\",\n    \"accountHolderName\": \"Business Name\"\n  }\n}"
              },
              "url": {
                "raw": "http://localhost:3004/api/payment/wallet/withdraw",
                "host": ["localhost:3004"],
                "path": ["api", "payment", "wallet", "withdraw"]
              },
              "description": "Withdraw funds from wallet"
