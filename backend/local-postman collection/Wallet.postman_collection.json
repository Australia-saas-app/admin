            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"WH-1234567890\",\n  \"event_type\": \"PAYMENT.CAPTURE.COMPLETED\",\n  \"resource\": {\n    \"id\": \"paypal_order_123\",\n    \"status\": \"COMPLETED\"\n  }\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/webhooks/paypal",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "webhooks", "paypal"]
            }
          },
          "response": []
        }
      ]
    },
