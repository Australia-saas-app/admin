{
  "info": {
    "_postman_id": "wallet-collection-id",
    "name": "Wallet Services",
    "description": "Vero2 Wallet Collection - covers Wallet Creation, Balance Management, Transaction Tracking, Integration with Other Services, Security & Fraud Prevention, Wallet Reporting & Analytics, Refund & Adjustment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "directUrl",
      "value": "http://localhost:3004",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "user123",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "order123",
      "type": "string"
    },
    {
      "key": "transactionId",
      "value": "txn123",
      "type": "string"
    },
    {
      "key": "cardId",
      "value": "card123",
      "type": "string"
    },
    {
      "key": "sessionId",
      "value": "session123",
      "type": "string"
    },
    {
      "key": "agencyId",
      "value": "agency123",
      "type": "string"
    },
    {
      "key": "affiliateId",
      "value": "affiliate123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Wallet Creation",
      "item": [
        {
          "name": "Get Wallet Balance",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Balance Management",
      "item": [
        {
          "name": "Add Payment Card",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cardHolderName\": \"John Doe\",\n  \"cardNumber\": \"4111111111111111\",\n  \"expiryMonth\": \"12\",\n  \"expiryYear\": \"2025\",\n  \"cvv\": \"123\",\n  \"cardType\": \"visa\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/cards",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "cards"]
            }
          },
          "response": []
        },
        {
          "name": "Add Funds to Wallet (Card Payment)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50.00,\n  \"currency\": \"USD\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/buy",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "buy"]
            }
          },
          "response": []
        },
        {
          "name": "Add Funds with Stripe",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50.00,\n  \"currency\": \"USD\",\n  \"paymentIntentId\": \"pi_1234567890\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/stripe/buy",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "stripe", "buy"]
            }
          },
          "response": []
        },
        {
          "name": "Withdraw from Wallet",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25.00,\n  \"currency\": \"USD\",\n  \"withdrawalMethod\": \"bank_transfer\",\n  \"accountDetails\": {\n    \"accountNumber\": \"123456789\",\n    \"routingNumber\": \"021000021\",\n    \"accountHolderName\": \"John Doe\",\n    \"bankName\": \"Test Bank\"\n  }\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/withdraw",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "withdraw"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transaction Tracking",
      "item": [
        {
          "name": "Get Transaction History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/transactions?page=1&limit=10",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "transactions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Integration with Other Services",
      "item": [
        {
          "name": "Pay for Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25.00,\n  \"description\": \"Payment for order {{orderId}}\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/pay/order/{{orderId}}",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "pay", "order", "{{orderId}}"]
            }
          },
          "response": []
        },
        {
          "name": "Create Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gateway\": \"stripe\",\n  \"currency\": \"USD\",\n  \"items\": [{\"name\": \"Wallet Top-up\", \"unitAmount\": 25.00, \"quantity\": 1}],\n  \"successUrl\": \"http://localhost:3000/success\",\n  \"cancelUrl\": \"http://localhost:3000/cancel\",\n  \"orderId\": \"{{orderId}}\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/checkout",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "checkout"]
            }
          },
          "response": []
        },
        {
          "name": "Get Checkout Session",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/checkout/{{sessionId}}?gateway=stripe",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "checkout", "{{sessionId}}"],
              "query": [
                {
                  "key": "gateway",
                  "value": "stripe"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Checkout Session",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/checkout/{{sessionId}}?gateway=stripe",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "checkout", "{{sessionId}}"],
              "query": [
                {
                  "key": "gateway",
                  "value": "stripe"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_1234567890\",\n  \"object\": \"event\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_1234567890\",\n      \"status\": \"succeeded\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/webhooks/stripe",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "webhooks", "stripe"]
            }
          },
          "response": []
        },
        {
          "name": "PayPal Webhook",
          "request": {
            "method": "POST",
