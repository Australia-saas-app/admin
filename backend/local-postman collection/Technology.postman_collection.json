{
  "info": {
    "name": "Vero2 Technology Service - Project Management",
    "description": "Postman collection for project management features: Project creation & lifecycle, Project management (Admin/Sub-Admin), Business participation & work tracking, Communication & access control, Status transitions",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
     {
       "key": "base_url",
       "value": "http://localhost:3011",
       "type": "string"
     },
     {
       "key": "auth_url",
       "value": "http://localhost:3001",
       "type": "string"
     },
     {
       "key": "adminBaseUrl",
       "value": "http://localhost:3007/admin-service",
       "type": "string"
     },
     {
       "key": "ssoBaseUrl",
       "value": "http://localhost:3001/sso",
       "type": "string"
     },
     {
       "key": "api_prefix",
       "value": "api/technical",
       "type": "string"
     },
     {
       "key": "jwt_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "admin_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "project_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "task_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "message_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login (Get JWT Token)",
           "request": {
             "method": "POST",
             "header": [
               {
                 "key": "Content-Type",
                 "value": "application/x-www-form-urlencoded"
               }
             ],
             "body": {
               "mode": "urlencoded",
               "urlencoded": [
                 {
                   "key": "grant_type",
                   "value": "password"
                 },
                 {
                   "key": "username",
                   "value": "user@example.com"
                 },
                 {
                   "key": "password",
                   "value": "Password123!"
                 }
               ]
             },
             "url": {
               "raw": "{{ssoBaseUrl}}/token",
               "host": ["{{ssoBaseUrl}}"],
               "path": ["token"]
             }
           },
           "event": [
             {
               "listen": "test",
               "script": {
                 "exec": [
                   "pm.collectionVariables.set(\"jwt_token\", pm.response.json().access_token);"
                 ]
               }
             }
           ]
        },
        {
          "name": "Admin Login (Get Admin Token)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPassword123!\"\n}"
             },
             "url": {
               "raw": "{{adminBaseUrl}}/auth/admin/login",
               "host": ["{{adminBaseUrl}}"],
               "path": ["auth", "admin", "login"]
             }
          }
        }
      ]
    },
    {
      "name": "Project Creation & Lifecycle",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sample Project\",\n  \"description\": \"Project description\",\n  \"startDate\": \"2024-01-01\",\n  \"endDate\": \"2024-12-31\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"project_id\", pm.response.json().projectId);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get My Projects",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Project",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Title\",\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "Delete Project",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Project Management (Admin/Sub-Admin)",
      "item": [
        {
          "name": "Add Participant",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"user123\",\n  \"userName\": \"John Doe\",\n  \"role\": \"member\",\n  \"accountType\": \"business\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}/participants",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}", "participants"]
            }
          }
        },
        {
          "name": "Update Participant Role",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"sub_admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}/participants/user123/role",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}", "participants", "user123", "role"]
            }
          }
        }
      ]
    },
    {
      "name": "Business Participation & Work Tracking",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Sample Task\",\n  \"description\": \"Task description\",\n  \"assignedTo\": \"user123\",\n  \"dueDate\": \"2024-06-01\",\n  \"priority\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}/tasks",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}", "tasks"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"task_id\", pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Project Tasks",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}/tasks?page=1&limit=10",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}", "tasks"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Task",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\",\n  \"priority\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "tasks", "{{task_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Communication & Access Control",
      "item": [
        {
          "name": "Post Message",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"messageType\": \"general\",\n  \"content\": \"Hello team!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}", "messages"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set(\"message_id\", pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Project Messages",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}/messages",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}", "messages"]
            }
          }
        },
        {
          "name": "Get Single Message",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/messages/{{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "messages", "{{message_id}}"]
            }
          }
        },
        {
          "name": "Update Message",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Updated message content\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/messages/{{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "messages", "{{message_id}}"]
            }
          }
        },
        {
          "name": "Delete Message",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/messages/{{message_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "messages", "{{message_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Status Transitions",
      "item": [
        {
          "name": "Transition Project Status (Draft to Active)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "Transition Project Status (Active to Completed)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/{{project_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "{{project_id}}"]
            }
          }
        },
        {
          "name": "Transition Task Status (Todo to In Progress)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "tasks", "{{task_id}}"]
            }
          }
        },
        {
          "name": "Transition Task Status (In Progress to Completed)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"completed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/projects/tasks/{{task_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "projects", "tasks", "{{task_id}}"]
            }
          }
        }
      ]
    }
  ]
}