  },
  "variable": [
    {
      "key": "adminBaseUrl",
      "value": "http://localhost:3007",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string",
      "description": "JWT token automatically set after login"
    }
  ],
  "item": [
    {
      "name": "🔐 Authentication & Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{adminBaseUrl}}/admin-service/health",
              "host": ["{{adminBaseUrl}}"],
              "path": ["admin-service", "health"]
            },
            "description": "Check if the admin service is healthy and running."
          }
        },
        {
          "name": "Register Admin (Bootstrap)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Extract token from register response and set as environment variable",
                  "if (pm.response.code === 201 || pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.data && response.data.token) {",
                  "        pm.environment.set('adminToken', response.data.token);",
                  "        console.log('Token set successfully from registration');",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPassword123!\",\n  \"fullName\": \"Admin User\",\n  \"bootstrapSecret\": \"change-me-bootstrap\"\n}"
            },
            "url": {
              "raw": "{{adminBaseUrl}}/admin-service/auth/admin/register",
              "host": ["{{adminBaseUrl}}"],
              "path": ["admin-service", "auth", "admin", "register"]
            },
            "description": "Register the first admin user using bootstrap secret. Required before login. Token will be auto-saved if returned."
          }
        },
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const response = pm.response.json();",
                  "    if (response.success && response.data && response.data.token) {",
                  "        const token = response.data.token;",
                  "        ",
                  "        // Save to environment (primary)",
                  "        pm.environment.set('adminToken', token);",
                  "        console.log('Token saved to environment');",
                  "        ",
                  "        // Save to collection variables",
                  "        pm.collectionVariables.set('adminToken', token);",
                  "        console.log('Token saved to collection variables');",
                  "        ",
                  "        // Save to globals as backup",
                  "        pm.globals.set('adminToken', token);",
                  "        console.log('Token saved to globals');",
                  "        ",
                  "        // Verify all locations",
                  "        const envToken = pm.environment.get('adminToken');",
                  "        const collToken = pm.collectionVariables.get('adminToken');",
                  "        const globalToken = pm.globals.get('adminToken');",
                  "        ",
                  "        console.log('Environment token length:', envToken ? envToken.length : 0);",
                  "        console.log('Collection token length:', collToken ? collToken.length : 0);",
                  "        console.log('Global token length:', globalToken ? globalToken.length : 0);",
                  "        ",
                  "        if (envToken || collToken || globalToken) {",
                  "            console.log('✅ Token saved successfully in at least one location');",
                  "        } else {",
                  "            console.log('❌ Token NOT saved anywhere');",
                  "        }",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"AdminPassword123!\"\n}"
            },
            "url": {
              "raw": "{{adminBaseUrl}}/admin-service/auth/admin/login",
              "host": ["{{adminBaseUrl}}"],
              "path": ["admin-service", "auth", "admin", "login"]
            },
            "description": "Login as admin and get JWT token. The token will be automatically saved to the adminToken environment variable."
          }
        }
      ]
