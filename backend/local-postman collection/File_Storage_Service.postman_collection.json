		{
			"name": "Presigned Upload - User Token",
			"item": [
				{
					"name": "Create Presigned Upload",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('presigned_file_id', response.id);",
									"    pm.collectionVariables.set('presigned_upload_url', response.uploadUrl);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token_user}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"filename\": \"document.pdf\",\n  \"mimeType\": \"application/pdf\",\n  \"size\": 1024000,\n  \"ownerId\": \"user-123\",\n  \"folderId\": \"{{folder_id}}\",\n  \"tags\": [\"document\", \"important\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/presign/upload",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"presign",
								"upload"
							]
						},
						"description": "Create a presigned upload URL for large files. Uses user JWT token."
					},
					"response": []
				},
				{
					"name": "Complete Presigned Upload",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token_user}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/{{presigned_file_id}}/upload",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"{{presigned_file_id}}",
								"upload"
							]
						},
						"description": "Complete the presigned upload and validate the file. Uses user JWT token."
					},
					"response": []
				}
			]
