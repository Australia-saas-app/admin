		{
			"name": "Files - User Token",
			"item": [
				{
					"name": "Upload File",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    const response = pm.response.json();",
									"    pm.collectionVariables.set('file_id', response.id);",
									"    pm.collectionVariables.set('file_key', response.key);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token_user}}",
								"type": "text",
								"description": "JWT token from SSO service (user login)"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "file",
									"type": "file",
									"src": [],
									"description": "The file to upload (required)"
								},
								{
									"key": "ownerId",
									"value": "user-123",
									"type": "text",
									"description": "Owner/user ID (optional - will use userId from token if not provided)"
								},
								{
									"key": "folderId",
									"value": "{{folder_id}}",
									"type": "text",
									"description": "Folder ID (optional)"
								},
								{
									"key": "tags",
									"value": "photo,profile",
									"type": "text",
									"description": "Comma-separated tags (optional) - Example: photo,profile"
								}
							]
						},
						"url": {
							"raw": "{{base_url}}",
							"host": [
								"{{base_url}}"
							]
						},
						"description": "Upload a file using user JWT token. The file will be validated and scanned automatically.\n\n**How to get user token:**\n1. Login to SSO service: POST http://localhost:3001/sso/auth/login\n2. Use the `accessToken` from response\n3. Set `jwt_token_user` variable in Postman"
					},
					"response": []
				},
				{
					"name": "List Files",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token_user}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}?limit=50&offset=0",
							"host": [
								"{{base_url}}"
							],
							"query": [
								{
									"key": "limit",
									"value": "50",
									"description": "Maximum number of results (optional, default: 100, max: 1000)"
								},
								{
									"key": "offset",
									"value": "0",
									"description": "Pagination offset (optional, default: 0)"
								}
							]
						},
						"description": "List all files with optional filtering and pagination. Uses user JWT token."
					},
					"response": []
