        {
          "name": "Configure Error Alerts",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertOnErrors\": true,\n  \"errorThreshold\": 10,\n  \"alertChannels\": [\"email\", \"slack\"],\n  \"alertRecipients\": [\"admin@example.com\"],\n  \"services\": [\"chat\", \"payment\", \"order\"]\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/errors/alerts/config",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "errors", "alerts", "config"]
            },
            "description": "Configure error alerting rules and thresholds"
          },
          "response": []
        },
        {
          "name": "Mark Error as Resolved",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"resolved\": true,\n  \"resolution\": \"Fixed by deploying hotfix v1.2.1\",\n  \"resolvedBy\": \"admin@example.com\",\n  \"preventiveAction\": \"Added input validation\"\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/errors/{{errorId}}/resolve",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "errors", "{{errorId}}", "resolve"]
            },
            "description": "Mark an error as resolved with resolution details"
          },
          "response": []
        },
