      "name": "Centralized Logging",
      "item": [
        {
          "name": "View Application Logs",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/logs/application?page=1&limit=50&service=chat&level=error",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "logs", "application"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "service",
                  "value": "chat",
                  "disabled": true
                },
                {
                  "key": "level",
                  "value": "error",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "",
                  "disabled": true
