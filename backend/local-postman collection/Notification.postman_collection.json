    "_exporter_id": "notification-service"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{JWT_TOKEN}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3005/notification-service",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "user_123",
      "type": "string"
    },
    {
      "key": "notification_id",
      "value": "notification_123",
      "type": "string"
    },
    {
      "key": "channel_id",
      "value": "channel_123",
      "type": "string"
    },
    {
      "key": "template_id",
      "value": "template_123",
      "type": "string"
    },
    {
      "key": "schedule_id",
