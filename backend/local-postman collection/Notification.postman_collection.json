   "item": [
     {
       "name": "Authentication",
       "item": [
         {
           "name": "Get JWT Token from SSO",
           "request": {
             "method": "POST",
             "header": [
               {
                 "key": "Content-Type",
                 "value": "application/json"
               }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"grant_type\": \"password\",\n  \"username\": \"user@example.com\",\n  \"password\": \"Password123!\",\n  \"client_id\": \"first-party-app\",\n  \"client_secret\": \"change-me-client-secret\"\n}"
             },
             "url": {
               "raw": "http://localhost:3001/sso/token",
               "host": ["http://localhost:3001"],
               "path": ["sso", "token"]
             },
             "description": "Get JWT token from SSO service. Update credentials as needed."
           },
           "event": [
             {
               "listen": "test",
               "script": {
                 "exec": [
                   "if (pm.response.code === 200) {",
                   "    const response = pm.response.json();",
                   "    pm.collectionVariables.set('JWT_TOKEN', response.access_token);",
                   "    console.log('JWT Token set successfully');",
                   "}"
                 ],
                 "type": "text/javascript"
               }
             }
           ]
         }
       ]
     },
