    {
      "name": "Alerts & Thresholds",
      "item": [
        {
          "name": "Create Analytics Alert",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Low Revenue Alert\",\n  \"description\": \"Alert when daily revenue drops below threshold\",\n  \"metric\": \"daily_revenue\",\n  \"condition\": \"less_than\",\n  \"threshold\": 1000.00,\n  \"timeWindow\": \"1day\",\n  \"channels\": [\"email\", \"slack\"],\n  \"recipients\": [\"admin@example.com\"],\n  \"enabled\": true\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/analytics/alerts",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "analytics", "alerts"]
            },
            "description": "Create analytics-based alerts and thresholds"
          },
          "response": []
        },
        {
          "name": "List Active Alerts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/analytics/alerts?page=1&limit=20&status=active",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "analytics", "alerts"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
