  },
  "item": [
    {
      "name": "Data Aggregation",
      "item": [
        {
          "name": "Aggregate User Data",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/analytics/aggregate/users?period=month&groupBy=country",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "analytics", "aggregate", "users"],
              "query": [
                {
                  "key": "period",
                  "value": "month"
                },
                {
                  "key": "groupBy",
                  "value": "country",
                  "disabled": true
                },
                {
                  "key": "startDate",
                  "value": "",
                  "disabled": true
                },
                {
                  "key": "endDate",
                  "value": "",
                  "disabled": true
                }
              ]
            },
            "description": "Aggregate user data for analytics processing"
          },
          "response": []
        },
        {
          "name": "Aggregate Transaction Data",
