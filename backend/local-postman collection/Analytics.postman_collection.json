{
  "info": {
    "_postman_id": "analytics-collection-id",
    "name": "Analytics Collection - Vero2",
    "description": "Comprehensive analytics system covering Data Aggregation, Real-time & Batch Processing, Business Analytics, User & Service Metrics, Custom Reports & Dashboards, Integration with Other Services, Alerts & Thresholds, and Data Storage & Archival. Based on existing analytics and reporting functionality in the admin service.",
