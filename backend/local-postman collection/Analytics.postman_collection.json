          "response": []
        },
        {
          "name": "Custom Data Aggregation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dataSource\": \"orders\",\n  \"aggregationType\": \"sum\",\n  \"field\": \"totalAmount\",\n  \"groupBy\": \"serviceType\",\n  \"filters\": {\n    \"status\": \"completed\",\n    \"dateRange\": {\n      \"start\": \"2024-01-01\",\n      \"end\": \"2024-12-31\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/analytics/aggregate/custom",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "analytics", "aggregate", "custom"]
            },
            "description": "Create custom data aggregation queries"
          },
          "response": []
        }
      ]
    },
