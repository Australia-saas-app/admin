              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/analytics/aggregate/services?period=month&groupBy=category",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "analytics", "aggregate", "services"],
              "query": [
                {
                  "key": "period",
                  "value": "month"
                },
                {
                  "key": "groupBy",
                  "value": "category",
                  "disabled": true
