              "path": ["admin-service", "analytics", "aggregate", "transactions"],
              "query": [
                {
                  "key": "period",
                  "value": "week"
                },
                {
                  "key": "groupBy",
                  "value": "paymentMethod",
                  "disabled": true
                }
              ]
            },
            "description": "Aggregate transaction data for financial analytics"
