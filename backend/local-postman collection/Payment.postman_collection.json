{
  "info": {
    "_postman_id": "payment-collection-id",
    "name": "Payment Services",
    "description": "Vero2 Payment Collection - covers Gateway Integration, Transaction Processing, Multi-Currency Support, Transaction History & Ledger, Security & Fraud Prevention, Refund & Chargeback, Payment Initialization, Payment Processing, Wallet Integration, Payment Status Tracking, Refund / Adjustment, Integration with Other Services, Security & Compliance, Reporting & Analytics",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "directUrl",
      "value": "http://localhost:3004",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "user123",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "order123",
      "type": "string"
    },
    {
      "key": "transactionId",
      "value": "txn123",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Payment Processing",
      "item": [
        {
          "name": "Process Payment for Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25.00,\n  \"description\": \"Payment for order {{orderId}}\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/pay/order/{{orderId}}",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "pay", "order", "{{orderId}}"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Transaction History & Ledger",
      "item": [
        {
          "name": "Get User Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{directUrl}}/api/payment/wallet/transactions?page=1&limit=10",
              "host": ["{{directUrl}}"],
              "path": ["api", "payment", "wallet", "transactions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Transaction Details",
          "request": {
            "method": "GET",
            "header": [
              {
