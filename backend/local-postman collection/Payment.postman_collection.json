              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refundAmount\": 50.00,\n  \"feesRefundedAmount\": 2.90,\n  \"reason\": \"Customer requested refund\"\n}"
            },
            "url": {
              "raw": "{{directUrl}}/admin/payments/transactions/{{transactionId}}/refund",
              "host": ["{{directUrl}}"],
              "path": ["admin", "payments", "transactions", "{{transactionId}}", "refund"]
