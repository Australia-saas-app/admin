    {
      "name": "Security & Audit",
      "item": [
        {
          "name": "Log Currency Conversion",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/audit/conversions?page=1&limit=20",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "audit", "conversions"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Audit log of all currency conversions performed"
          },
          "response": []
        },
        {
          "name": "Log Exchange Rate Changes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/audit/rates?page=1&limit=20",
