{
  "info": {
    "_postman_id": "currency-collection-id",
    "name": "Currency Collection - Vero2",
    "description": "Currency management system covering Currency Catalog/Management, Exchange Rate Management, Currency Conversion, Integration with Other Services, Currency Formatting & Display, Security & Audit, and Reporting & Analytics. Based on existing currency functionality across services.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Currency Catalog / Management",
      "item": [
        {
          "name": "Get Supported Currencies",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/supported",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "supported"]
            },
            "description": "Get list of all supported currencies in the system"
          },
          "response": []
        },
        {
          "name": "Get Currency Details",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/{{currencyCode}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "{{currencyCode}}"]
            },
            "description": "Get detailed information about a specific currency"
          },
          "response": []
        },
        {
          "name": "Add Supported Currency (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"EUR\",\n  \"name\": \"Euro\",\n  \"symbol\": \"€\",\n  \"decimalPlaces\": 2,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies"]
            },
            "description": "Add a new supported currency to the system"
          },
          "response": []
        },
        {
          "name": "Update Currency Settings (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"€\",\n  \"decimalPlaces\": 2,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/{{currencyCode}}",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "{{currencyCode}}"]
            },
            "description": "Update currency settings and display properties"
          },
          "response": []
        },
        {
          "name": "Disable Currency (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isActive\": false\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/{{currencyCode}}/status",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "{{currencyCode}}", "status"]
            },
            "description": "Enable or disable a currency for use in the system"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Exchange Rate Management",
      "item": [
        {
          "name": "Get Current Exchange Rates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/exchange-rates?base=USD",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "exchange-rates"],
              "query": [
                {
                  "key": "base",
                  "value": "USD"
                }
              ]
            },
            "description": "Get current exchange rates for all supported currencies"
          },
          "response": []
        },
        {
          "name": "Get Exchange Rate for Currency Pair",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/exchange-rates/USD/EUR",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "exchange-rates", "USD", "EUR"]
            },
            "description": "Get exchange rate between two specific currencies"
          },
          "response": []
        },
        {
          "name": "Update Exchange Rates (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"baseCurrency\": \"USD\",\n  \"rates\": {\n    \"EUR\": 0.85,\n    \"GBP\": 0.73,\n    \"JPY\": 110.50\n  },\n  \"source\": \"manual\"\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/exchange-rates",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "exchange-rates"]
            },
            "description": "Update exchange rates manually or from external provider"
          },
          "response": []
        },
        {
          "name": "Get Exchange Rate History",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/exchange-rates/USD/EUR/history?days=30",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "exchange-rates", "USD", "EUR", "history"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            },
            "description": "Get historical exchange rate data"
          },
          "response": []
        },
        {
          "name": "Set Preferred Exchange Rate Provider (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"provider\": \"fixer\",\n  \"apiKey\": \"your-fixer-api-key\",\n  \"updateIntervalMinutes\": 60\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/exchange-rates/provider",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "exchange-rates", "provider"]
            },
            "description": "Configure external exchange rate provider"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Currency Conversion",
      "item": [
        {
          "name": "Convert Currency Amount",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00,\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"EUR\"\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/convert",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "convert"]
            },
            "description": "Convert an amount from one currency to another"
          },
          "response": []
        },
        {
          "name": "Bulk Currency Conversion",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversions\": [\n    {\n      \"amount\": 100.00,\n      \"fromCurrency\": \"USD\",\n      \"toCurrency\": \"EUR\"\n    },\n    {\n      \"amount\": 50.00,\n      \"fromCurrency\": \"USD\",\n      \"toCurrency\": \"GBP\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/convert/bulk",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "convert", "bulk"]
            },
            "description": "Convert multiple amounts at once"
          },
          "response": []
        },
        {
          "name": "Convert with Historical Rate",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00,\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"EUR\",\n  \"date\": \"2024-01-15\"\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/convert/historical",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "convert", "historical"]
            },
            "description": "Convert using historical exchange rates"
          },
          "response": []
        },
        {
          "name": "Get Conversion Fee",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/convert/fees?from=USD&to=EUR&amount=100",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "convert", "fees"],
              "query": [
                {
                  "key": "from",
                  "value": "USD"
                },
                {
                  "key": "to",
                  "value": "EUR"
                },
                {
                  "key": "amount",
                  "value": "100"
                }
              ]
            },
            "description": "Calculate conversion fees for a transaction"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Integration with Other Services",
