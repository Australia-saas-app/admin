            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/security/settings",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "security", "settings"]
            },
            "description": "Configure security settings for currency operations"
          },
          "response": []
        }
      ]
