              "mode": "raw",
              "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"EUR\",\n  \"amount\": 100.00,\n  \"expectedRate\": 0.85,\n  \"maxDeviation\": 0.05\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/validate/conversion",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "validate", "conversion"]
            },
            "description": "Validate currency conversion against expected rates for fraud prevention"
          },
          "response": []
        },
