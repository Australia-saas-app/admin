          "name": "Format for Multiple Locales",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1234.56,\n  \"currency\": \"EUR\",\n  \"locales\": [\"en-US\", \"de-DE\", \"fr-FR\"]\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/api/currencies/format/multi-locale",
              "host": ["{{gatewayUrl}}"],
              "path": ["api", "currencies", "format", "multi-locale"]
            },
            "description": "Format currency for multiple locales"
          },
          "response": []
        },
        {
          "name": "Update Currency Display Settings (Admin)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"$\",\n  \"symbolPosition\": \"before\",\n  \"decimalSeparator\": \".\",\n  \"thousandsSeparator\": \",\",\n  \"decimalPlaces\": 2\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/admin-service/currencies/USD/display",
              "host": ["{{gatewayUrl}}"],
              "path": ["admin-service", "currencies", "USD", "display"]
            },
            "description": "Configure how currency amounts are displayed"
          },
          "response": []
        }
      ]
