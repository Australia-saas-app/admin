{
  "info": {
    "name": "Vero2-Education-Service.postman_collection",
    "description": "Postman collection for Vero2 Education Service API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3015",
      "type": "string"
    },
    {
      "key": "jwtToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Courses",
      "item": [
        {
          "name": "Get All Courses (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/education/courses?page=1&limit=10&search=javascript",
              "host": ["{{baseUrl}}"],
              "path": ["education", "courses"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "search",
                  "value": "javascript"
                }
              ]
            }
          }
        },
        {
          "name": "Get Course Details (Public)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/education/courses/EDU-ABC123",
              "host": ["{{baseUrl}}"],
              "path": ["education", "courses", "EDU-ABC123"]
            }
          }
        },
        {
          "name": "Create Course (Authenticated)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Complete Web Development Bootcamp\",\n  \"description\": \"Learn full-stack web development from scratch\",\n  \"category\": \"Programming\",\n  \"price\": 99.99,\n  \"durationHours\": 40,\n  \"thumbnail\": \"https://example.com/thumbnail.jpg\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/education/courses",
              "host": ["{{baseUrl}}"],
              "path": ["education", "courses"]
            }
          }
        },
         {
           "name": "Create Course (Admin)",
           "request": {
             "method": "POST",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{adminToken}}"
               },
               {
                 "key": "Content-Type",
                 "value": "application/json"
               }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"title\": \"Complete Web Development Bootcamp\",\n  \"description\": \"Learn full-stack web development from scratch\",\n  \"category\": \"Programming\",\n  \"price\": 99.99,\n  \"durationHours\": 40,\n  \"thumbnail\": \"https://example.com/thumbnail.jpg\"\n}"
             },
             "url": {
               "raw": "{{baseUrl}}/education/courses/admin",
               "host": ["{{baseUrl}}"],
               "path": ["education", "courses", "admin"]
             }
           }
         },
         {
           "name": "Update Course (Admin)",
           "request": {
             "method": "PATCH",
             "header": [
               {
                 "key": "Authorization",
                 "value": "Bearer {{adminToken}}"
               },
               {
                 "key": "Content-Type",
                 "value": "application/json"
               }
             ],
             "body": {
               "mode": "raw",
               "raw": "{\n  \"title\": \"Updated Course Title\",\n  \"price\": 149.99\n}"
             },
             "url": {
               "raw": "{{baseUrl}}/education/courses/EDU-ABC123",
               "host": ["{{baseUrl}}"],
               "path": ["education", "courses", "EDU-ABC123"]
             }
           }
         }
      ]
    },
