              "raw": "{{base_url}}/{{api_prefix}}/properties/agent/{{property_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "properties", "agent", "{{property_id}}"]
            },
            "description": "Delete a property created by the authenticated **agency**."
          },
          "response": []
        }
      ]
    },
