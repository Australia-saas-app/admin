              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/properties/{{property_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "properties", "{{property_id}}"]
            },
            "description": "Delete real estate property (Admin). Permanently removes the property."
          },
          "response": []
        },
        {
          "name": "Toggle Property Visibility",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
