              "raw": "{{base_url}}/{{api_prefix}}/properties/{{property_id}}/visibility",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "properties", "{{property_id}}", "visibility"]
            },
            "description": "Toggle property visibility (Admin ONLY). \n\n⚠️ REQUIRES ADMIN TOKEN - This endpoint is for admins to manage property visibility. \n\nUsers/agencies can CREATE properties but cannot change visibility - this is an admin function.\n\nUse admin_token from: POST {{ssoBaseUrl}}/auth/admin/login\n\nBody: {\"isVisible\": true} or {\"isVisible\": false}"
          },
          "response": []
        },
