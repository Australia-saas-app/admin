          "name": "Get All Active Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/services/categories/list?page=1&limit=50&isActive=",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "services", "categories", "list"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number"
                },
                {
                  "key": "limit",
                  "value": "50",
                  "description": "Items per page"
                },
                {
                  "key": "isActive",
                  "value": "",
                  "description": "Filter by active status (admin only)"
                }
              ]
            },
            "description": "Get all active construction categories (Public). Only active categories are returned."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Categories - Admin",
      "item": [
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    if (response.categoryId) {",
                  "        pm.collectionVariables.set('category_id', response.categoryId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Residential Construction\",\n  \"description\": \"Residential construction services including houses, apartments, and residential buildings\",\n  \"displayOrder\": 1,\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/services/categories",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "services", "categories"]
            },
            "description": "Create new construction category (Admin). Category name must be unique."
          },
          "response": []
        },
        {
          "name": "Get All Categories (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/services/admin/categories/list?page=1&limit=50&isActive=",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "services", "admin", "categories", "list"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "isActive",
                  "value": "",
                  "description": "Filter by active status (true/false)"
                }
              ]
            },
            "description": "Get all construction categories including inactive ones (Admin)"
          },
          "response": []
        },
        {
          "name": "Get Category by ID (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/services/admin/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "services", "admin", "categories", "{{category_id}}"]
            },
            "description": "Get single category details by category ID (Admin)"
          },
          "response": []
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Residential Construction\",\n  \"description\": \"Updated category description\",\n  \"isActive\": true,\n  \"displayOrder\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/services/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "services", "categories", "{{category_id}}"]
            },
            "description": "Update construction category (Admin). Partial updates supported."
          },
          "response": []
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/{{api_prefix}}/services/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["{{api_prefix}}", "services", "categories", "{{category_id}}"]
            },
            "description": "Delete construction category (Admin). Only allowed if no services are using this category."
          },
          "response": []
        }
      ]
    }
  ],
