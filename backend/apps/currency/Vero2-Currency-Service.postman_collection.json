              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "variable": [
              {
                "key": "id",
                "value": ""
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rate\": 0.90\n}"
            }
          },
          "response": []
