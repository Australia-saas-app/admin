        {
          "name": "Delete Exchange Rate",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/exchange-rates/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "exchange-rates", ":id"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              }
            ],
            "variable": [
              {
                "key": "id",
                "value": ""
              }
            ]
          },
          "response": []
        }
      ]
