              "mode": "raw",
              "raw": "{\n  \"fromCurrencyCode\": \"USD\",\n  \"toCurrencyCode\": \"EUR\",\n  \"rate\": 0.85,\n  \"effectiveDate\": \"2024-01-01T00:00:00Z\",\n  \"source\": \"manual\"\n}"
            }
          },
          "response": []
