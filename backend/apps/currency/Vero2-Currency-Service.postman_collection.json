          },
          "response": []
        },
        {
          "name": "Get Base Currency",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/currencies/base",
              "host": ["{{baseUrl}}"],
              "path": ["api", "currencies", "base"]
            }
          },
          "response": []
        },
        {
          "name": "Get Currency by ID",
          "request": {
            "method": "GET",
