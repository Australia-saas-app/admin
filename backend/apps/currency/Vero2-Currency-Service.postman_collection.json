              "raw": "{\n  \"fromCurrency\": \"USD\",\n  \"toCurrency\": \"EUR\",\n  \"amount\": 100,\n  \"serviceName\": \"payment\",\n  \"referenceId\": \"order-12345\",\n  \"referenceType\": \"order\"\n}"
