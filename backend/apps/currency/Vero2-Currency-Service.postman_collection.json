              "raw": "{{baseUrl}}/api/currencies/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "currencies", ":id"]
            },
            "variable": [
              {
                "key": "id",
                "value": ""
              }
            ]
          },
          "response": []
        },
        {
          "name": "Get Currency by Code",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/currencies/code/:code",
              "host": ["{{baseUrl}}"],
