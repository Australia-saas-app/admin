            },
            "variable": [
              {
                "key": "code",
                "value": "USD"
              }
            ]
          },
          "response": []
        },
        {
          "name": "Update Currency",
          "request": {
            "method": "PUT",
            "url": {
              "raw": "{{baseUrl}}/api/currencies/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "currencies", ":id"]
            },
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwtToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "variable": [
              {
                "key": "id",
                "value": ""
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"US Dollar Updated\",\n  \"isActive\": true\n}"
            }
          },
          "response": []
        },
        {
          "name": "Delete Currency",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/api/currencies/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "currencies", ":id"]
