    {
      "name": "Project Payments",
      "item": [
        {
          "name": "Stripe Checkout (One-time)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json.paymentIntentId) {",
                  "  pm.collectionVariables.set('stripe_payment_intent_id', json.paymentIntentId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{payer_token}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessUserId\": \"{{business_user_id}}\",\n  \"amount\": 250.00,\n  \"currency\": \"USD\",\n  \"projectId\": \"{{project_id}}\",\n  \"paymentKind\": \"one_time\",\n  \"description\": \"One-time project payment\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/payments/stripe/checkout",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "payments",
                "stripe",
                "checkout"
              ]
            }
          }
        },
