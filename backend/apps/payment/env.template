# Server Configuration
PORT=3004
# Set to 'production' for Docker/production deployments
# Set to 'development' for local development
NODE_ENV=production

# Database Configuration
DB_HOST=host.docker.internal
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=vero2

# SSO Authentication
SSO_PUBLIC_KEY=-----BEGIN PUBLIC KEY----------END PUBLIC KEY-----
SSO_ISSUER=http://localhost:3001/sso

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Stripe (required for /wallet/stripe/* routes)
# Replace with your real Stripe secret key (test: sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# PayPal (required for /wallet/paypal/* and /checkout?gateway=paypal routes)
# Replace with your real PayPal client ID and secret (sandbox or live)
PAYPAL_CLIENT_ID=your_paypal_client_id_here
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_MODE=sandbox

# Wallet defaults
WALLET_DEFAULT_CURRENCY=USD


