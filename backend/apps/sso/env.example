# ============================================
# SSO Service Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3001
HOST=0.0.0.0

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_database_password
DB_NAME=vero2

# Database Synchronization
# Set to true to auto-sync schema (use false in production)
SSO_SYNCHRONIZE=true

# ============================================
# Redis Configuration
# ============================================
# Option 1: Use Redis URL (recommended)
REDIS_URL=redis://localhost:6379

# Option 2: Use individual host/port (if REDIS_URL is not set)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ============================================
# JWT/SSO Configuration
# ============================================
# RSA Private Key for signing JWT tokens (PEM format)
# Generate with: openssl genrsa -out private.pem 2048
# For multi-line keys, use \n for newlines or keep as single line
SSO_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----

# RSA Public Key for verifying JWT tokens (PEM format)
# Generate with: openssl rsa -in private.pem -pubout -out public.pem
SSO_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nYour public key here\n-----END PUBLIC KEY-----

# SSO Issuer URL (used in JWT tokens)
# Default: http://localhost:3001/sso
SSO_ISSUER=http://localhost:3001/sso

# Access Token TTL in seconds (default: 900 = 15 minutes)
ACCESS_TOKEN_TTL=604800

# Refresh Token TTL in seconds (default: 1209600 = 14 days)
REFRESH_TOKEN_TTL=1209600

# ============================================
# OAuth Client Configuration
# ============================================
# Default OAuth client ID (used when client_id is not provided)
DEFAULT_CLIENT_ID=first-party-app

# Default OAuth client secret (CHANGE IN PRODUCTION!)
DEFAULT_CLIENT_SECRET=replace-me-in-production

# Default OAuth scope
DEFAULT_SCOPE=openid profile email offline_access

# ============================================
# Rate Limiting Configuration
# ============================================
# Rate limit time window in seconds (default: 60)
RATE_LIMIT_TTL=60

# Maximum requests per time window (default: 100)
RATE_LIMIT_MAX=100

# ============================================
# OTP (One-Time Password) Configuration
# ============================================
# OTP expiration time in seconds (default: 600 = 10 minutes)
OTP_TTL_SECONDS=600

# ============================================
# Stripe Payment Configuration (for Wallet)
# ============================================
# Stripe Secret Key (use test key for development: sk_test_...)
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Publishable Key (use test key for development: pk_test_...)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Webhook Secret (optional, for webhook signature verification)
# Get from: https://dashboard.stripe.com/test/webhooks
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# PayPal Payment Configuration (for Wallet)
# ============================================
# PayPal Client ID
# Get from: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=your_paypal_client_id_here

# PayPal Client Secret
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here

# PayPal Mode: 'sandbox' for testing, 'live' for production
PAYPAL_MODE=sandbox

# PayPal Webhook ID (optional, for webhook signature verification)
# Get from: https://developer.paypal.com/dashboard/webhooks
# PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here

# PayPal Return URL (where users are redirected after payment)
PAYPAL_RETURN_URL=http://localhost:3000/wallet/paypal/return

# PayPal Cancel URL (where users are redirected if they cancel)
PAYPAL_CANCEL_URL=http://localhost:3000/wallet/paypal/cancel

# ============================================
# Order Service Integration
# ============================================
# Order Service URL for wallet payment integration
ORDER_SERVICE_URL=http://localhost:3003/api/orders
ORDER_SERVICE_TIMEOUT=10000

# ============================================
# Wallet Settings
# ============================================
WALLET_MIN_TOPUP=10.00
WALLET_MAX_TOPUP=10000.00
WALLET_MIN_WITHDRAWAL=50.00
WALLET_MAX_WITHDRAWAL=5000.00
WALLET_DAILY_WITHDRAWAL_LIMIT=2000.00

# ============================================
# AWS SES SMTP Configuration (for OTP emails)
# ============================================
# SES SMTP Server Host (varies by AWS region)
# US East (N. Virginia): email-smtp.us-east-1.amazonaws.com
# US West (Oregon): email-smtp.us-west-2.amazonaws.com
# Europe (Ireland): email-smtp.eu-west-1.amazonaws.com
SES_SMTP_HOST=email-smtp.us-east-1.amazonaws.com

# SES SMTP Port (587 for TLS, 465 for SSL, 25 for none)
SES_SMTP_PORT=587

# SES SMTP Credentials (get from AWS SES console -> SMTP Settings)
SES_SMTP_USER=your_ses_smtp_username
SES_SMTP_PASSWORD=your_ses_smtp_password

# SES Verified Email Configuration
# From email address (must be verified in SES)
SES_FROM_EMAIL=noreply@yourdomain.com

# From name that appears in emails
SES_FROM_NAME=Vero2 Platform

# ============================================
# SMS Configuration (Optional - for OTP SMS)
# ============================================
# TODO: Add SMS provider configuration when implemented
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ============================================
# Notes
# ============================================
# 1. For production, set NODE_ENV=production
# 2. Generate strong RSA keys for SSO_PRIVATE_KEY and SSO_PUBLIC_KEY
# 3. Use strong passwords for database and Redis
# 4. Never commit actual credentials to version control
# 5. Use environment-specific values for different deployments
# 6. For Stripe, use test keys (sk_test_/pk_test_) in development
# 7. For Stripe production, use live keys (sk_live_/pk_live_)

