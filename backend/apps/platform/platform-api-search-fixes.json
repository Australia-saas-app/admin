            }
          }
        }
      ]
    },
    {
      "name": "Blogs",
      "item": [
        {
          "name": "Get All Blogs (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/blogs?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "blogs"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Search Blogs by Title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/blogs/search/test",
              "host": ["{{baseUrl}}"],
              "path": ["blogs", "search", "test"]
            }
          }
        }
      ]
    },
    {
      "name": "Contact Us",
      "item": [
        {
          "name": "Get All Contacts (Admin)",
