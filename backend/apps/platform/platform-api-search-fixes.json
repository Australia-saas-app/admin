          }
        },
        {
          "name": "Search Contacts by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/contact-us/search/test",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "contact-us", "search", "test"]
            }
          }
        }
      ]
    },
    {
      "name": "Team",
      "item": [
        {
          "name": "Get All Team Members (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/team?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "team"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Departments (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/team/departments",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "team", "departments"]
            }
          }
        },
        {
          "name": "Get Departments (Public)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/team/departments",
              "host": ["{{baseUrl}}"],
              "path": ["team", "departments"]
            }
          }
        },
        {
          "name": "Search Team by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/team/search/test",
              "host": ["{{baseUrl}}"],
              "path": ["team", "search", "test"]
            }
          }
        },
        {
          "name": "Create Team Member",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/team",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "team"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"position\": \"Software Engineer\",\n  \"department\": \"Engineering\",\n  \"email\": \"john.doe@example.com\",\n  \"photoUrl\": \"https://example.com/photo.jpg\",\n  \"bio\": \"Experienced developer\",\n  \"linkedinUrl\": \"https://linkedin.com/in/johndoe\"\n}"
            }
          }
        },
        {
          "name": "Update Team Member",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/admin/team/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "team", ":id"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Smith\",\n  \"position\": \"Senior Engineer\",\n  \"department\": \"Engineering\"\n}"
            }
          }
        },
        {
          "name": "Toggle Team Member Visibility",
          "request": {
            "method": "PATCH",
            "url": {
              "raw": "{{baseUrl}}/admin/team/:id/visibility",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "team", ":id", "visibility"]
            }
          }
        },
        {
          "name": "Delete Team Member",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{baseUrl}}/admin/team/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "team", ":id"]
            }
          }
        }
      ]
    },
