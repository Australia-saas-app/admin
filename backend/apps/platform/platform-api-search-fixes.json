{
  "info": {
    "name": "Platform API - Admin Endpoints",
    "description": "Collection for testing Platform Admin APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/platform",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}"
      }
    ]
  },
  "item": [
    {
      "name": "Gallery",
      "item": [
        {
          "name": "Get All Galleries (Admin)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/gallery?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "gallery"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Search Galleries by Title",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/gallery/search/test",
              "host": ["{{baseUrl}}"],
              "path": ["gallery", "search", "test"]
            }
          }
        }
      ]
    },
    {
