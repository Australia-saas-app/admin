{
  "info": {
    "name": "Vero2 User Profile - Admin Endpoints",
    "description": "Postman collection for admin endpoints in user-profile service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "adminToken",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "KYC Management",
      "item": [
        {
          "name": "Get Pending KYC Submissions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/kyc/pending?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "kyc", "pending"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get KYC Details by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/kyc/:id",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "kyc", ":id"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Review KYC Submission",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/admin/kyc/:id/review",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "kyc", ":id", "review"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"notes\": \"Documents verified successfully\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            }
          }
        }
      ]
    },
    {
      "name": "Profile Management (Admin)",
      "item": [
        {
          "name": "Get User Profile by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/profile/:userId",
              "host": ["{{baseUrl}}"],
              "path": ["profile", ":userId"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get Pending KYC (Profile)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/profile/kyc/pending?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "kyc", "pending"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Get KYC by ID (Profile)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/profile/kyc/:id",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "kyc", ":id"]
            },
            "header": [
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ]
          }
        },
        {
          "name": "Review KYC (Profile)",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{baseUrl}}/profile/kyc/:id/review",
              "host": ["{{baseUrl}}"],
              "path": ["profile", "kyc", ":id", "review"]
            },
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"notes\": \"Documents verified\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            }
          }
        }
      ]
    }
  ]
}