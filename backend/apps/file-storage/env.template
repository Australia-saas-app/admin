NODE_ENV=development
PORT=3009

# Database (Postgres) - align with your shared DB setup
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=vero2

# Rate limiting
RATE_LIMIT_TTL=60
# requests per ttl window
RATE_LIMIT_MAX=100

# Cloudflare R2 Storage (S3-compatible)
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=https://your-domain.com  # Optional: for generating public URLs

# Legacy Local Storage (commented out - replaced with R2)
# LOCAL_STORAGE_PATH=/app/storage
BASE_URL=http://localhost:3009/api/files

# Upload limits (bytes) - example 10MB
MAX_UPLOAD_BYTES=10485760

# File Type Validation
# Comma-separated list of allowed MIME types (leave empty for defaults)
# Default includes: images, documents, archives, audio, video
# Example: ALLOWED_MIME_TYPES=image/jpeg,image/png,application/pdf
ALLOWED_MIME_TYPES=

# Comma-separated list of allowed file extensions (leave empty for defaults)
# Example: ALLOWED_FILE_EXTENSIONS=jpg,png,pdf,doc,docx
ALLOWED_FILE_EXTENSIONS=

# Antivirus Scanning
# Set to 'true' to enable basic antivirus scanning (content analysis)
# For production, integrate with ClamAV daemon for full scanning
ENABLE_ANTIVIRUS_SCAN=true

# SSO Service Configuration (Required for JWT verification)
# Get the public key from your SSO service
# Format: -----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Or as single line with \n escape sequences
SSO_PUBLIC_KEY=

# SSO Service Issuer (default: http://localhost:3001/sso)
# In Docker, use: http://sso:3001/sso
SSO_ISSUER=http://localhost:3001/sso

