    {
      "name": "Wallet - Transactions",
      "item": [
        {
          "name": "Get User Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{ssoToken}}",
                "description": "JWT access token for authentication"
              }
            ],
            "url": {
              "raw": "{{paymentUrl}}/api/payment/wallet/transactions?page=1&limit=10&type=deposit&status=completed",
              "host": ["{{paymentUrl}}"],
              "path": ["api", "payment", "wallet", "transactions"],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number for pagination"
                },
                {
                  "key": "limit",
                  "value": "10",
                  "description": "Number of items per page"
                },
                {
                  "key": "type",
                  "value": "deposit",
                  "description": "Filter by transaction type (deposit, withdrawal, payment, refund)"
                },
                {
                  "key": "status",
                  "value": "completed",
                  "description": "Filter by transaction status (pending, completed, failed)"
                },
                {
                  "key": "startDate",
                  "value": "2024-01-01",
                  "description": "Filter transactions from this date (YYYY-MM-DD)"
                },
                {
                  "key": "endDate",
                  "value": "2024-12-31",
                  "description": "Filter transactions until this date (YYYY-MM-DD)"
                }
              ]
            },
            "description": "Get transaction history for the authenticated user\n\n**Query Parameters:**\n- `page` (integer, optional): Page number (default: 1)\n- `limit` (integer, optional): Items per page (default: 10)\n- `type` (string, optional): Filter by transaction type (deposit, withdrawal, payment, refund)\n- `status` (string, optional): Filter by status (pending, completed, failed)\n- `startDate` (string, optional): Start date filter (YYYY-MM-DD)\n- `endDate` (string, optional): End date filter (YYYY-MM-DD)\n- `currency` (string, optional): Filter by currency"
          },
          "response": []
        },
