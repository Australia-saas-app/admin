{
	"info": {
		"_postman_id": "509d8a5e-a231-44e0-b51d-613d01abe190",
		"name": "Chat Messaging - Vero2",
		"description": "Endpoints for direct messaging between users and businesses (agencies).",
		"schema": "https://schema.getpostman.com/json/collection/v2.0.0/collection.json",
		"_exporter_id": "19531119"
	},
	"item": [
		{
			"name": "Direct Messaging",
			"item": [
				{
					"name": "Search Chat Users",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{chat_url}}/api/chat/messages/search-users?name=John",
							"host": [
								"{{chat_url}}"
							],
							"path": [
								"api",
								"chat",
								"messages",
								"search-users"
							],
							"query": [
								{
									"key": "name",
									"value": "John"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "User to Business Message",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "businessId",
									"value": "{{agency_id}}",
									"type": "text"
								},
								{
									"key": "content",
									"value": "Hello, I am interested in your services.",
									"type": "text"
								},
								{
									"key": "attachments",
									"description": "Optional file attachments",
									"type": "file",
									"src": []
								}
							]
						},
						"url": "{{chat_url}}/api/chat/messages/user-to-business"
					},
					"response": []
				},
				{
					"name": "Business to User Message",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "userId",
									"value": "{{user_id}}",
									"type": "text"
								},
								{
									"key": "content",
									"value": "Thank you for reaching out! How can we help you?",
									"type": "text"
								},
								{
									"key": "attachments",
									"description": "Optional file attachments",
									"type": "file",
									"src": []
								}
							]
						},
						"url": "{{chat_url}}/api/chat/messages/business-to-user"
					},
					"response": []
				},
				{
					"name": "Soft Delete User to Business Message",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{chat_url}}/api/chat/messages/user-to-business/:id",
							"host": [
								"{{chat_url}}"
							],
							"path": [
								"api",
								"chat",
								"messages",
								"user-to-business",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "{{message_id}}"
								}
							]
						}
					},
					"response": []
				},
				{
					"name": "Soft Delete Business to User Message",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{chat_url}}/api/chat/messages/business-to-user/:id",
							"host": [
								"{{chat_url}}"
							],
							"path": [
								"api",
								"chat",
								"messages",
								"business-to-user",
								":id"
							],
							"variable": [
								{
									"key": "id",
									"value": "{{message_id}}"
								}
							]
						}
					},
					"response": []
				}
			]
		},
