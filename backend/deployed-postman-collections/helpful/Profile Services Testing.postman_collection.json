	"item": [
		{
			"name": "User Profile Service",
			"item": [
				{
					"name": "Get Current User Profile",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{jwt_token}}"
							}
						],
						"url": {
							"raw": "{{user_profile_url}}/profile",
							"host": [
								"{{user_profile_url}}"
							],
							"path": [
								"profile"
							]
						}
					},
					"response": []
				},
