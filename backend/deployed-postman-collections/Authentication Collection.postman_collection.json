    {
      "name": "Logging & Audit",
      "item": [
        {
          "name": "List Users (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{adminBaseUrl}}/auth/admin/users",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "auth",
                "admin",
                "users"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get User Details (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{adminBaseUrl}}/auth/admin/users/{{userId}}",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "auth",
                "admin",
                "users",
                "{{userId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update User Status (Admin)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"active\",\n  \"reason\": \"Verified documents\"\n}"
            },
            "url": {
              "raw": "{{adminBaseUrl}}/auth/admin/users/{{userId}}/status",
              "host": [
                "{{adminBaseUrl}}"
              ],
              "path": [
                "auth",
                "admin",
                "users",
                "{{userId}}",
                "status"
              ]
            }
          },
          "response": []
        }
      ]
    },
