# Copy this file to `.env` (never commit the real file) and replace every
# placeholder with a strong secret. Secrets must be at least 32 random bytes,
# e.g. run `openssl rand -base64 48`.

# Application database (PostgreSQL)
POSTGRES_USER=postgres_admin
POSTGRES_PASSWORD=change-me-postgres-admin
POSTGRES_DB=vero2_core

# Service-specific PostgreSQL credentials
BACKEND_DB_USER=vero2_backend_app
BACKEND_DB_PASSWORD=change-me-backend
BACKEND_DB_NAME=vero2_backend

SSO_DB_USER=vero2_sso_app
SSO_DB_PASSWORD=change-me-sso
SSO_DB_NAME=vero2_sso

# Kong database credentials
KONG_PG_USER=kong_app
KONG_PG_PASSWORD=change-me-kong
KONG_PG_DATABASE=kong_gateway

# MongoDB credentials
MONGO_INITDB_ROOT_USERNAME=vero2_mongo_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-admin
MONGO_DB_NAME=vero2
MONGO_APP_USER=vero2_mongo_app
MONGO_APP_PASSWORD=change-me-mongo-app

# Redis credentials
REDIS_PASSWORD=change-me-redis

# JWT and OAuth secrets
JWT_SECRET=replace-with-strong-32-byte-secret
JWT_EXPIRY=3600
SSO_CLIENT_ID=first-party-app
SSO_CLIENT_SECRET=replace-with-strong-client-secret

# SSO signing keys (store real keys outside of VCS)
# Provide PEM content as a single line with literal \n sequences or load via mounted files.
SSO_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\\nREPLACE_WITH_BASE64_ENCODED_KEY\\n-----END PRIVATE KEY-----"
SSO_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\\nREPLACE_WITH_BASE64_ENCODED_KEY\\n-----END PUBLIC KEY-----"

# Redis hostnames/ports
REDIS_HOST=redis
REDIS_PORT=6379

# Backend configuration
BACKEND_PORT=3000
NODE_ENV=production
MONGODB_URI=mongodb://vero2_mongo_app:change-me-mongo-app@mongo:27017/vero2?authSource=admin
# (Update the URI if you change the Mongo user/password/database above)
SSO_TOKEN_URL=http://sso:3001/sso/token

# SSO service configuration
SSO_PORT=3001
SSO_ISSUER=http://sso:3001/sso
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600
SSO_SYNCHRONIZE=true

# Platform Service configuration
PLATFORM_PORT=3006
PLATFORM_POSTGRES_USER=vero2_platform_app
PLATFORM_POSTGRES_PASSWORD=change-me-platform
PLATFORM_POSTGRES_DB=vero2_platform
PLATFORM_MONGODB_URI=mongodb://vero2_mongo_app:change-me-mongo-app@mongo:27017/vero2_platform?authSource=admin
PLATFORM_MONGODB_DB_NAME=vero2_platform
PLATFORM_NODE_ENV=development
PLATFORM_RATE_LIMIT_MAX=500

# Admin Service configuration
ADMIN_PORT=3007
ADMIN_DB_USER=vero2_admin_app
ADMIN_DB_PASSWORD=change-me-admin
ADMIN_DB_NAME=vero2_admin
ADMIN_NODE_ENV=development
ADMIN_RATE_LIMIT_MAX=500
ADMIN_BOOTSTRAP_SECRET=change-me-bootstrap

# Security & rate limiting
OTP_TTL_SECONDS=600
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

ADMIN_BOOTSTRAP_SECRET=change-me-bootstrap
