{
  "name": "frontend-monorepo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --filter=system-db",
    "dev:web": "turbo run dev --filter=system-db",
    "docker:dev": "docker compose up --build",
    "docker:start": "docker compose up --build -d",
    "docker:stop": "docker compose down",
    "docker:restart": "docker compose down && docker compose up --build -d",
    "docker:logs": "docker compose logs -f",
    "docker:build": "docker compose build",
    "docker:prod": "docker compose -f docker-compose.prod.yml up --build",
    "gcp:setup": "bash scripts/gcp-setup.sh",
    "gcp:deploy": "gcloud builds submit --config=cloudbuild.yaml",
    "build": "turbo run build",
    "build:cloudflare": "turbo run build:cloudflare --filter=system-db",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@vitejs/plugin-react": "^4.5.2",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^15.5.2",
    "next": "^16.0.7",
    "prettier": "^3.6.2",
    "turbo": "^2.10.5",
    "vitest": "^3.2.4",
    "wrangler": "4.107.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,css}": "prettier --write"
  },
  "packageManager": "pnpm@9.0.0",
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1",
      "postcss": "^8.5.10"
    }
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opennextjs/cloudflare": "^1.19.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@smastrom/react-rating": "^1.5.0",
    "@tanstack/react-query": "^5.90.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.12.2",
    "body-scroll-lock": "^4.0.0-beta.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "critters": "^0.0.25",
    "framer-motion": "^12.23.24",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.545.0",
    "react": "^19.2.1",
    "react-datepicker": "^8.8.0",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.65.0",
    "react-icons": "^5.5.0",
    "react-select": "^5.10.2",
    "recharts": "^2.15.3",
    "socket.io-client": "^4.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  }
}
